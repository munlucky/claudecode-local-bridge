{
  "name": "claudecode-codex-local-bridge",
  "version": "2.0.0",
  "description": "Anthropic-compatible local bridge for Claude Code backed by codex app-server and local Codex auth",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.template",
    "TEST_GUIDE.md"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "typecheck": "tsc --noEmit",
    "verify:bridge": "node scripts/verify-ollama-bridge.mjs",
    "test": "bun test tests",
    "prepack": "bun run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/munlucky/claudecode-codex-local-bridge.git"
  },
  "homepage": "https://github.com/munlucky/claudecode-codex-local-bridge#readme",
  "bugs": {
    "url": "https://github.com/munlucky/claudecode-codex-local-bridge/issues"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
