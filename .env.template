ROUTER_LISTEN_HOST=127.0.0.1
ROUTER_LISTEN_PORT=3000

# codex = 기존 Codex backend (기본값)
# ollama = Ollama API 기반 backend (예: qwen3.5:27b)
BRIDGE_BACKEND=codex

CODEX_AUTH_MODE=local_auth_json
CODEX_AUTH_FILE=~/.codex/auth.json
CODEX_OPENAI_API_KEY=
CODEX_COMMAND=codex
CODEX_RUNTIME_CWD=~/.codex/bridge-runtime
CODEX_SANDBOX_MODE=workspace-write
CODEX_INIT_TIMEOUT_MS=15000
CODEX_TURN_TIMEOUT_MS=180000
CODEX_TURN_REQUEST_TIMEOUT_MS=180000
ROUTER_IDLE_TIMEOUT_SEC=185

ROUTER_USER_AGENT=claudecode-codex-local-bridge/2.0
ROUTER_LOG_REQUESTS=1
ROUTER_CAPTURE_REQUESTS=1
ROUTER_CAPTURE_REQUESTS_PATH=.history/anthropic-requests.jsonl
ROUTER_CAPTURE_RESPONSES=1
ROUTER_CAPTURE_RESPONSES_PATH=.history/anthropic-responses.jsonl
ROUTER_CAPTURE_MAX_FILE_BYTES=5242880
ROUTER_CAPTURE_RETENTION_DAYS=7
ROUTER_HEARTBEAT_INTERVAL_SEC=30

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:27b
OLLAMA_API_KEY=
OLLAMA_REQUEST_TIMEOUT_MS=120000
OLLAMA_SHOW_THINKING=0
OLLAMA_MODEL_ALIASES_JSON=

CODEX_MODEL_OPUS=gpt-5.4
CODEX_MODEL_SONNET=gpt-5.4
CODEX_MODEL_HAIKU=gpt-5.4-mini
# MODEL_ALIASES_JSON={"claude-sonnet-4-5-20250929":"gpt-5.4"}
